{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
  },
  "include": ["src",
    "src/config.ts"
  ]
}
